# Vision-to-Cart V4 Environment Variables

# MCP Server Config
PORT=8000
HOST=0.0.0.0
ENV=development

# LLM Providers (OpenAI, Gemini)
OPENAI_API_KEY=your-openai-key-here # For GPT-4o, GPT-4o mini, text-embedding-3-small
GEMINI_API_KEY=your-gemini-key-here # For Gemini 1.5 Flash (Free Tier)

# Web Search APIs
TAVILY_API_KEY=your-tavily-key-here # Recommended paid/trial search
BRAVE_SEARCH_API_KEY=your-brave-key-here # Free alternative (2,000 queries/month)

# Data Store Connections
REDIS_HOST=localhost
REDIS_PORT=6379
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200

# Directory Paths (Optional overrides)
CHROMADB_PERSIST_DIR=data_services/vector_store
CATALOG_PATH=data_services/catalog/catalog.json
ENRICHED_CATALOG_PATH=data_services/catalog/catalog_enriched.json
